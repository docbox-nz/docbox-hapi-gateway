{
  "name": "@docbox-nz/hapi-gateway",
  "version": "0.3.0",
  "description": "Docbox hapi server gateway",
  "license": "MIT",
  "author": "Jacobtread",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docbox-nz/docbox-hapi-gateway.git"
  },
  "type": "module",
  "main": "./dist/index.browser.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "default": "./dist/index.d.ts"
      },
      "default": {
        "require": "./dist/index.node.cjs",
        "default": "./dist/index.node.esm.js"
      }
    }
  },
  "scripts": {
    "build": "rolldown -c",
    "prepublishOnly": "npm run build",
    "watch": "rolldown -c --watch",
    "fmt": "oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "axios": "^1.16.1"
  },
  "devDependencies": {
    "@hapi/boom": "^10.0.1",
    "@types/node": "^24.12.4",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "rolldown": "^1.0.1"
  },
  "peerDependencies": {
    "@hapi/hapi": "^20.1.0 || ^21.0.0"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
